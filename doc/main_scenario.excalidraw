    {
      "id": "v4_WQunhrSC7-f5nbaywM",
      "type": "text",
      "x": 254.8364755249022,
      "y": 155.20703125,
      "width": 1403.449951171875,
      "height": 249.19140625000006,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
